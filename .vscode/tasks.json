{
            "version": "2.0.0",
                "tasks": [
                        {
                                    "label": "Run C Program",
                                                "type": "shell",
                                                            "command": "bash",
                                                                        "args": [
                                                                                        "-c",
                                                                                                        "gcc '${file}' -o '${fileBasenameNoExtension}' && './${fileBasenameNoExtension}'"
                                                                                                                    ],
                                                                                                                                "group": {
                                                                                                                                                "kind": "build",
                                                                                                                                                                "isDefault": true
                                                                                                                                                                            },
                                                                                                                                                                                        "presentation": {
                                                                                                                                                                                                        "reveal": "always",
                                                                                                                                                                                                                        "panel": "new"
                                                                                                                                                                                                                                    }
                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                ]
                                                                                                                                                                                                                                                }

